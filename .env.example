# Server
PORT=8080
SHUTDOWN_TIMEOUT=5s

# Webhook dispatcher
WEBHOOK_MAX_RETRIES=3
WEBHOOK_CHANNEL_BUFFER=100
WEBHOOK_HTTP_TIMEOUT=5s

# Idempotency
IDEMPOTENCY_TTL=24h

# Security — set this to a strong random string in production.
# Token creation (POST /v1/tokens) requires this key in the X-Admin-Key header.
ADMIN_API_KEY=dev_admin_secret_key

